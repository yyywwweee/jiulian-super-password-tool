#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
BUILD_FILE="$ROOT/BUILD_NUMBER"
GEN_SCRIPT="$ROOT/scripts/generate_version.sh"

if [[ ! -f "$BUILD_FILE" ]]; then
  echo "0" > "$BUILD_FILE"
fi
BUILD="$(tr -d '[:space:]' < "$BUILD_FILE")"
if ! [[ "$BUILD" =~ ^[0-9]+$ ]]; then BUILD="0"; fi
BUILD=$((BUILD + 1))
echo "$BUILD" > "$BUILD_FILE"

"$GEN_SCRIPT"
git add "$ROOT/VERSION" "$ROOT/BUILD_NUMBER" "$ROOT/platforms/macos/Sources/JiulianSuperPasswordTool/GeneratedVersion.swift"
