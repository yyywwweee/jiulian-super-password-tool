#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
BUILD_FILE="$ROOT/BUILD_NUMBER"

if [[ ! -f "$BUILD_FILE" ]]; then
  echo "0" > "$BUILD_FILE"
fi
BUILD="$(tr -d '[:space:]' < "$BUILD_FILE")"
if ! [[ "$BUILD" =~ ^[0-9]+$ ]]; then BUILD="0"; fi
BUILD=$((BUILD + 1))
echo "$BUILD" > "$BUILD_FILE"

git add "$ROOT/VERSION" "$ROOT/BUILD_NUMBER"
